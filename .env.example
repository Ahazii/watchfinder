# Copy to `.env` for local development (not used by Unraid — set variables in the container template).
# -----------------------------------------------------------------------------

# --- PostgreSQL (hostname must match your Postgres container on watchfinder-net) ---
DATABASE_URL=postgresql+psycopg://watchfinder:CHANGE_ME@watchfinder-postgres:5432/watchfinder

# --- eBay (Buy Browse API — client credentials) ---
# Create an app at https://developer.ebay.com — new accounts may wait for eBay authorization
# before production keys / Browse API access work. Until then, UI runs; ingest will error in logs.
EBAY_CLIENT_ID=
EBAY_CLIENT_SECRET=
EBAY_ENVIRONMENT=production
EBAY_MARKETPLACE_ID=EBAY_GB
EBAY_SEARCH_QUERY=wristwatch
# Default Browse page size (1–200) until Settings UI saves an override to app_settings.ingest_search_limit
EBAY_SEARCH_LIMIT=50
# How many search pages (offset steps) to fetch per query line (1–20); UI persists app_settings.ingest_max_pages
INGEST_MAX_PAGES=1
# Optional: Commerce Taxonomy get_category_tree(...)
# EBAY_CATEGORY_TREE_ID=

# --- Runtime ---
TZ=Europe/London
APP_PORT=8080
LOG_LEVEL=INFO
# Default ingest interval; Settings UI can persist app_settings.ingest_interval_minutes
INGEST_INTERVAL_MINUTES=30

# Stale listing batch refresh (Browse getItem for active rows past min age). Off by default.
# Enable in Settings UI (persists app_settings) or set STALE_LISTING_REFRESH_ENABLED=true
STALE_LISTING_REFRESH_ENABLED=false
STALE_LISTING_REFRESH_INTERVAL_MINUTES=360
STALE_LISTING_REFRESH_MAX_PER_RUN=20
# 0 = any active listing with last_seen_at in the past (good for testing right after ingest)
STALE_LISTING_REFRESH_MIN_AGE_HOURS=12

# Cached watch images from eBay listing gallery (written after catalog link). Docker: mount volume on LOCAL_MEDIA_ROOT.
LOCAL_MEDIA_ROOT=./data/media
MEDIA_DOWNLOAD_ENABLED=true
# MEDIA_DOWNLOAD_USER_AGENT=

# WatchBase on-demand import (watch model detail button). Set false to disable POST import.
WATCHBASE_IMPORT_ENABLED=true
# Optional HTTP User-Agent override for WatchBase requests
# WATCHBASE_HTTP_USER_AGENT=
# Comma-separated brand names to hide from GET /api/watch-models and skip catalog link/create/backfill
# (case-insensitive), e.g. Apple,Fitbit. Detail by UUID and manual POST /api/watch-models still work.
# WATCH_CATALOG_EXCLUDED_BRANDS=

# Everywatch + Chrono24 snapshot fetch (analyze/backfill + manual refresh on watch model detail).
# Chrono24 often returns HTTP 403 to the server; UI still exposes search/Google links.
EXTRA_MARKET_IMPORT_ENABLED=true
# Skip auto refresh if last snapshot newer than this many hours (1–168)
MARKET_SNAPSHOT_COOLDOWN_HOURS=24
# Optional GBP-per-EUR when Frankfurter (ECB) FX API is unreachable; import still sets manual low/high
# EUR_GBP_RATE_FALLBACK=0.85

# --- Internal comps (optional; not an env var) ---
# Cap for “same brand” asking-price comp sample: set Postgres row
#   INSERT INTO app_settings (key, value_text) VALUES ('max_comp_candidates', '200');
# If unset, the app defaults to 200. See README → Valuation & internal comps.

# --- Frontend (Next.js `npm run dev` only; omit in Docker / same-origin prod) ---
# NEXT_PUBLIC_API_BASE=http://127.0.0.1:8080
